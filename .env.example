# Chave da API OpenWeather (https://openweathermap.org)
VITE_OPENWEATHER_API_KEY=SUA_CHAVE_AQUI

# Cidade padrão para previsão do tempo
VITE_WEATHER_CITY=Pannonia Gols

# Chave do Service Account do Firebase (JSON) — para o backend
# Gerar em: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SA_KEY={"type":"service_account","project_id":"worklog-f1824",...}
